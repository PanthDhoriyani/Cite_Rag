# all secrets and config values — never commit this file
# copy to .env and fill in your values

# ── Databases ─────────────────────────────────────────────────────
# MongoDB Atlas (Cloud) Connection String (e.g. mongodb+srv://user:pass@cluster.mongodb.net)
MONGODB_URL=mongodb://localhost:27017

# Qdrant Cloud credentials
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

GROQ_API_KEY=

# ── Models ────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
LLM_MODEL=llama-3.1-8b-instant

# ── Pipeline Tuning ───────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=128
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANKER_TOP_K=10
CONFIDENCE_THRESHOLD=0.65

# ── Upload ────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── LangSmith Observability ───────────────────────────────────────
# Traces every LangChain component + @traceable functions automatically.
# Get your API key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=citerag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
