# ── Databases ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (mongodb+srv://user:pass@cluster.mongodb.net)
MONGODB_URL=mongodb://localhost:27017

# Qdrant Cloud credentials
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LLM & Embedding API Keys ──────────────────────────────────────────────────
# Groq API key — for LLM inference (llama-3.1-8b-instant)
# Get yours free at: https://console.groq.com
GROQ_API_KEY=

# Cohere API key — for cloud embeddings (embed-english-v3.0) and reranking (rerank-v3.5)
# Get your free Trial key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ── Model Names ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=embed-english-v3.0
RERANKER_MODEL=rerank-v3.5
LLM_MODEL=llama-3.1-8b-instant

# Embedding output dimension — must match EMBEDDING_MODEL output (1024 for Cohere)
EMBEDDING_DIM=1024

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=128
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANKER_TOP_K=10
CONFIDENCE_THRESHOLD=0.30

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ── LangSmith Observability ───────────────────────────────────────────────────
# Traces every LangChain component + @traceable functions automatically.
# Get your API key at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cite_rag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
