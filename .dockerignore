# =============================================================================
# .dockerignore — Exclude files from Docker build context
# =============================================================================
# Files listed here are NOT sent to the Docker daemon during `docker build`.
# This keeps the image small and prevents secrets from leaking into the image.
# =============================================================================

# ── Virtual Environment ───────────────────────────────────────────────────────
# Never include venv — Docker installs deps from requirements.txt itself
backend/venv/
venv/
.venv/
env/

# ── Python Cache ──────────────────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ── Secrets & Config ──────────────────────────────────────────────────────────
# .env contains API keys — never bake them into the image
.env

# ── Uploaded Files ────────────────────────────────────────────────────────────
# User uploads don't belong in the image (mounted as a volume in prod)
backend/uploads/
uploads/

# ── Development Tooling ───────────────────────────────────────────────────────
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo

# ── Documentation ────────────────────────────────────────────────────────────
*.md
!README.md

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Model Cache (handled by Docker volume, not baked in) ─────────────────────
.cache/
models/

# ── Test Files ────────────────────────────────────────────────────────────────
backend/test_*.py

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
