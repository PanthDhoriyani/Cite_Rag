# ── Python ─────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so

# ── Virtual Environment ─────────────────────
venv/
.venv/
env/
ENV/

# ── Environment Variables ───────────────────
.env
# Keep .env.example (template) — never commit real .env

# ── Uploads (user files — not tracked) ─────
uploads/

# ── IDEs ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS files ────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────
*.log
logs/

# ── Node / Frontend ─────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.next/

# ── Docker ──────────────────────────────────
# Keep docker-compose.yml and Dockerfiles tracked
# Ignore local override files
docker-compose.override.yml

# ── Testing ─────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
